{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "create-react-app",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{build/**,node_modules/**,src/backend/test_*.py,src/backend/init_sample_data.py,src/backend/data/**,**/__pycache__/**,**/*.pyc}"
    }
  },
  "rewrites": [
    { "source": "/api",        "destination": "/api/index.py" },
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/(.*)",       "destination": "/index.html"   }
  ],
  "crons": [
    { "path": "/api/cron/lembretes-atraso",    "schedule": "0 11 * * *" },
    { "path": "/api/cron/lembretes-devolucao", "schedule": "0 11 * * *" },
    { "path": "/api/cron/backup-diario",       "schedule": "0 16 * * *" }
  ]
}